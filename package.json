		"setup": "node scripts/setup.js"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.21.0",
		"obsidian": "latest",
		"tslib": "2.6.0",
		"typescript": "5.0.4"
	}
}
