{
	"name": "obsidian-todo-harvest",
	"version": "0.1.0",
	"description": "Gather todos from your notes into a sidebar panel",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
